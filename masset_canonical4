let
    // Combines all source-specific queries. Each source query resolves its own raw table
    // using a literal (non-computed) table name, which keeps data-source access exempt
    // from Power Query's dynamic-data-source restriction. Adding a source means adding a
    // corresponding query, following the same pattern, and including it in this list.
    Combined = Table.Combine({SourceA_Clean, SourceB_Clean}),

    // Restricts and orders columns to the canonical field list, read directly from the
    // field-mapping table rather than hardcoded -- adding or removing a canonical field
    // requires only a field-mapping edit.
    ReorderList = List.Combine({{"Source_System"}, tblFieldMapping[Canonical_Field]}),
    Reordered = Table.SelectColumns(Combined, ReorderList),

    // Translates raw values to canonical values for the three fields that require it:
    // Status, Scope, and Funding_Flag. Each field keeps the same name after translation as
    // before (e.g. "Status" throughout, never "Status_Raw"), while the untranslated value
    // is preserved permanently under "<Field>_Raw" (e.g. "Status_Raw") so a mapping issue
    // can be investigated directly from the output without a separate staging table. This
    // requires producing the translated value under a temporary name, renaming the
    // untranslated original to "<Field>_Raw", then moving the translated value into the
    // now-free original name, since a table cannot hold two columns with the same name.
    //
    // Each field is translated via an explicit merge against its own mapping table, rather
    // than a single loop selecting the mapping table dynamically, since resolving a data
    // source from a computed value is what triggers Power Query's dynamic-data-source
    // restriction. Referencing another named query directly, as done here, carries no such
    // restriction -- only resolving a data source from a runtime-computed value does.
    //
    // MAINTENANCE: adding a fourth value-translated field requires a fourth block below,
    // following the same four-step pattern (merge, expand, rename raw, rename final).
    //
    // HARDCODED: "Status"/"Scope"/"Funding_Flag" as the three translated field names;
    // "Source_System" and "Raw_Value" as the join-key column names each mapping table must
    // use; "Canonical_Value" as the translated-value column name each mapping table must
    // use; the "_Translated" temporary-name suffix (visible only mid-query) and the "_Raw"
    // suffix (permanent, appears in the final output); the three mapping-table query names
    // referenced directly (tblStatusMap/tblScopeMap/tblFundingMap).
    MergeStatus = Table.NestedJoin(Reordered, {"Source_System", "Status"}, tblStatusMap,
        {"Source_System", "Raw_Value"}, "StatusJoin", JoinKind.LeftOuter),
    ExpandStatus = Table.ExpandTableColumn(MergeStatus, "StatusJoin", {"Canonical_Value"}, {"Status_Translated"}),
    RenameStatusRaw = Table.RenameColumns(ExpandStatus, {{"Status", "Status_Raw"}}),
    RenameStatusFinal = Table.RenameColumns(RenameStatusRaw, {{"Status_Translated", "Status"}}),

    MergeScope = Table.NestedJoin(RenameStatusFinal, {"Source_System", "Scope"}, tblScopeMap,
        {"Source_System", "Raw_Value"}, "ScopeJoin", JoinKind.LeftOuter),
    ExpandScope = Table.ExpandTableColumn(MergeScope, "ScopeJoin", {"Canonical_Value"}, {"Scope_Translated"}),
    RenameScopeRaw = Table.RenameColumns(ExpandScope, {{"Scope", "Scope_Raw"}}),
    RenameScopeFinal = Table.RenameColumns(RenameScopeRaw, {{"Scope_Translated", "Scope"}}),

    MergeFunding = Table.NestedJoin(RenameScopeFinal, {"Source_System", "Funding_Flag"}, tblFundingMap,
        {"Source_System", "Raw_Value"}, "FundingJoin", JoinKind.LeftOuter),
    ExpandFunding = Table.ExpandTableColumn(MergeFunding, "FundingJoin", {"Canonical_Value"}, {"Funding_Flag_Translated"}),
    RenameFundingRaw = Table.RenameColumns(ExpandFunding, {{"Funding_Flag", "Funding_Flag_Raw"}}),
    ValueMapped = Table.RenameColumns(RenameFundingRaw, {{"Funding_Flag_Translated", "Funding_Flag"}}),

    // Item_ID is a composite key (Source_System + Source_ID), not a copy of Source_ID.
    // Source_ID alone is guaranteed unique only within a single source system; if two
    // source systems ever produced the same raw ID, Source_ID collisions would corrupt the
    // Review_Log lookup below, silently attaching one item's review decision to a
    // different item. The composite key removes any dependency on distinct ID conventions
    // being maintained indefinitely across every source.
    //
    // HARDCODED: "-" as the separator between Source_System and Source_ID. Changing this
    // format invalidates every Item_ID already recorded in Review_Log -- avoid changing it
    // once review history exists.
    AddItemID = Table.AddColumn(ValueMapped, "Item_ID", each [Source_System] & "-" & [Source_ID]),

    // The formulas below encode specific business rules -- what "overdue" means, what
    // counts as a "potential duplicate" -- rather than performing a generic transformation,
    // so field names are intentionally hardcoded rather than data-driven. Making rules of
    // this kind configurable would require a general rule-evaluation engine for marginal
    // benefit, and would make the underlying logic harder to inspect and audit.
    //
    // HARDCODED: "Closed" as the Status value meaning an item is no longer active (used
    // throughout this query, not only here); "Due_Date" as the field driving the overdue
    // calculation.
    AddDaysOverdue = Table.AddColumn(AddItemID, "Days_Overdue", each
        if [Status] = "Closed" or [Due_Date] = null then 0
        else List.Max({0, Duration.Days(DateTime.LocalNow() - [Due_Date])})),
    AddIsOverdue = Table.AddColumn(AddDaysOverdue, "Is_Overdue", each if [Days_Overdue] > 0 then "Yes" else "No"),

    // Duplicate detection matches the first N characters of Title (trimmed and
    // upper-cased, so whitespace and casing differences do not defeat the match) rather
    // than matching on Category. Text-prefix matching produces fewer false positives, at
    // the cost of missing duplicates worded differently beyond the compared prefix.
    //
    // HARDCODED: "Title" as the field compared; "Prefix_Length" as the duplicate-detection
    // configuration table's own column name. N itself is not hardcoded -- it is read from
    // that configuration table, so sensitivity can be retuned by editing a single value and
    // refreshing, with no code change.
    PrefixLength = tblDedupConfig{0}[Prefix_Length],
    AddSignature = Table.AddColumn(AddIsOverdue, "Signature", each
        Text.Start(Text.Trim(Text.Upper([Title])), PrefixLength)),

    // Resolves each item's region via a merge against a country-to-region mapping table,
    // rather than a per-row lookup, keeping this performant on a large dataset.
    // Global-scope items and items with no country receive no region bucket, since they
    // apply everywhere rather than to a specific area. A country absent from the mapping
    // table produces a visible "Unknown Region: <country>" value rather than failing
    // silently.
    //
    // HARDCODED: "Global" as the Scope value meaning an item applies everywhere;
    // "Region_Country" as the field holding an item's country; "Country" and
    // "Region_Bucket" as the region-mapping table's own column names; the literal text
    // "Unknown Region: " prefixing an unmapped country.
    MergeCountryBucket = Table.NestedJoin(AddSignature, {"Region_Country"}, tblCountryRegionMap,
        {"Country"}, "CountryJoin", JoinKind.LeftOuter),
    ExpandCountryBucket = Table.ExpandTableColumn(MergeCountryBucket, "CountryJoin", {"Region_Bucket"}, {"Region_Bucket_Raw"}),
    AddRegionBucket = Table.AddColumn(ExpandCountryBucket, "Region_Bucket", each
        if [Scope] = "Global" or [Region_Country] = null or [Region_Country] = "" then null
        else if [Region_Bucket_Raw] <> null then [Region_Bucket_Raw]
        else "Unknown Region: " & [Region_Country]),
    DropRawBucket = Table.RemoveColumns(AddRegionBucket, {"Region_Bucket_Raw"}),

    // Clusters items sharing a Signature among currently open items only; a closed item is
    // excluded from consideration and does not contribute to any other item's cluster
    // size. Table.Group combined with List.Distinct produces an exact distinct count of
    // regions and countries per cluster in a single pass.
    OpenForClustering = Table.SelectRows(DropRawBucket, each [Status] <> "Closed"),
    ClusterStats = Table.Group(OpenForClustering, {"Signature"}, {
        {"ClusterSize", each Table.RowCount(_), Int64.Type},
        {"HasGlobal", each List.Contains(_[Scope], "Global"), type logical},
        {"BucketCount", each List.Count(List.Distinct(List.RemoveNulls(_[Region_Bucket]))), Int64.Type},
        {"CountryCount", each List.Count(List.Distinct(List.RemoveNulls(_[Region_Country]))), Int64.Type}
    }),

    // Classifies each cluster's scope level:
    //   1) any member is Global-scope                          -> Global
    //   2) members span more than one region bucket             -> Global
    //   3) members span more than one country within one bucket -> Regional
    //   4) members share a single country                       -> Local
    //
    // HARDCODED: the four output values "Global"/"Regional"/"Local"/null, and the
    // evaluation order of the four conditions (rule 1 takes priority over rule 2, and so on).
    AddSuggestion = Table.AddColumn(ClusterStats, "Suggested_Scope_Level", each
        if [ClusterSize] <= 1 then null
        else if [HasGlobal] then "Global"
        else if [BucketCount] > 1 then "Global"
        else if [CountryCount] > 1 then "Regional"
        else "Local"),
    ClusterLookup = Table.SelectColumns(AddSuggestion, {"Signature", "ClusterSize", "Suggested_Scope_Level"}),

    // Applies cluster-level results to every row, including closed items, which are then
    // explicitly reset to "No"/null below regardless of whether they share a signature
    // with an open cluster -- a closed item is out of scope for duplicate review.
    MergeCluster = Table.NestedJoin(DropRawBucket, {"Signature"}, ClusterLookup, {"Signature"}, "ClusterJoin", JoinKind.LeftOuter),
    ExpandCluster = Table.ExpandTableColumn(MergeCluster, "ClusterJoin", {"ClusterSize", "Suggested_Scope_Level"}, {"ClusterSize", "Suggested_Scope_Level"}),

    AddIsPotentialDup = Table.AddColumn(ExpandCluster, "Is_Potential_Duplicate", each
        if [Status] = "Closed" or [ClusterSize] = null or [ClusterSize] <= 1 then "No" else "Yes"),
    FixScopeForClosed = Table.AddColumn(AddIsPotentialDup, "Suggested_Scope_Level_Final", each
        if [Status] = "Closed" then null else [Suggested_Scope_Level]),
    DropIntermediate = Table.RemoveColumns(FixScopeForClosed, {"ClusterSize", "Suggested_Scope_Level"}),
    RenameScope = Table.RenameColumns(DropIntermediate, {{"Suggested_Scope_Level_Final", "Suggested_Scope_Level"}}),

    // Brings in manually recorded review decisions, keyed by Item_ID. The review table is
    // kept separate from this query specifically because a refresh rebuilds this query's
    // output from scratch; any value entered directly into this query's result would be
    // lost on the next refresh.
    //
    // HARDCODED: "Item_ID" as the join key -- must exist, spelled exactly this way, on the
    // review table; "Review_Status" and "Reviewed_Scope_Level" as the two review-table
    // column names pulled into this output (the review table's other columns are not
    // referenced here).
    MergeReview = Table.NestedJoin(RenameScope, {"Item_ID"}, tblReviewLog, {"Item_ID"}, "ReviewJoin", JoinKind.LeftOuter),
    ExpandReview = Table.ExpandTableColumn(MergeReview, "ReviewJoin",
        {"Review_Status", "Reviewed_Scope_Level"}, {"Review_Status", "Reviewed_Scope_Level"}),

    // Defines the final output schema. The raw/passthrough fields are read directly from
    // the field-mapping table -- adding a canonical field there flows through to the
    // output automatically, with no risk of it being silently dropped at this step. Each
    // translated field's raw counterpart (e.g. Status_Raw) is placed immediately after it,
    // rather than grouped separately, since the raw value is most useful positioned next
    // to its translated counterpart when investigating a mapping issue.
    //
    // HARDCODED: "Item_ID" and "Source_System" (computed earlier, not present in the
    // field-mapping table); {"Status","Scope","Funding_Flag"} as the fields that receive a
    // _Raw counterpart -- this list must be kept in sync with the explicit merge blocks
    // above; adding a fourth translated field means updating both places. The "_Raw"
    // suffix itself (must match the suffix used above); the computed-field names at the
    // end (Days_Overdue, Is_Overdue, Signature, Region_Bucket, Is_Potential_Duplicate,
    // Suggested_Scope_Level, Review_Status, Reviewed_Scope_Level) -- none of these exist in
    // the field-mapping table, so they cannot be derived and must be listed explicitly.
    // Adding a field computed within this query (rather than sourced from a source system)
    // requires adding its name to this list; Table.SelectColumns raises an immediate error
    // if a listed name does not exist at this point, which guards against a typo in this
    // list or an upstream step failing to produce an expected column.
    FieldsWithRawCounterpart = {"Status", "Scope", "Funding_Flag"},
    FieldOrderWithRaw = List.Combine(
        List.Transform(tblFieldMapping[Canonical_Field], each
            if List.Contains(FieldsWithRawCounterpart, _)
            then {_, _ & "_Raw"}
            else {_}
        )
    ),
    FinalOrder = Table.SelectColumns(
        ExpandReview,
        List.Combine({
            {"Item_ID", "Source_System"},
            FieldOrderWithRaw,
            {"Days_Overdue", "Is_Overdue", "Signature", "Region_Bucket",
             "Is_Potential_Duplicate", "Suggested_Scope_Level", "Review_Status", "Reviewed_Scope_Level"}
        })
    )
in
    FinalOrder
